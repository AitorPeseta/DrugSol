prefix=/mnt/c/URV/TFG/DrugSol/envs/drugsol-bert-manual
exec_prefix=/mnt/c/URV/TFG/DrugSol/envs/drugsol-bert-manual
libdir=${prefix}/lib
includedir=${prefix}/include

