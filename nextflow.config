/*
 * -------------------------------------------------
 * Nextflow config file for DrugSol Prediction
 * -------------------------------------------------
 */

// 1. Project Manifest (Metadata for your TFG)
manifest {
    name            = 'drugsol-predictor'
    author          = 'Àitor Olivares Perucho'
    description     = 'Solubility predictor using XGBoost, LightGBM, Chemprop, and Regression with temperature weighting.'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=22.10.1'
    version         = '1.0.0'
}

// 2. Global Parameters
params {
    outdir = "${launchDir}/results"
}

// 3. Executor & Resources
workDir = "${baseDir}/work"

// 4. Conda / Mamba Configuration
conda {
    enabled  = true
    useMicromamba = true
    cacheDir = "${baseDir}/envs/conda_cache" 
}

// 5. Process Specific Configuration
process {
    // Fail fast if something goes wrong
    errorStrategy = 'finish' 

    // Disable cache for the ensembling/blending step to ensure it always runs with latest inputs
    withName: '.*meta_stack_blend.*' {
        cache = false
    }
}

// 6. Profiles
profiles {
    standard {
        process.executor = 'local'
    }
    
    docker {
        conda.enabled = false
        docker.enabled = true
    }
}