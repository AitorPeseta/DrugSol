/*
========================================================================================
    DrugSol Predictor - Nextflow Configuration
========================================================================================
    Machine learning pipeline for aqueous solubility prediction using:
    - XGBoost, LightGBM, CatBoost (gradient boosting)
    - Chemprop D-MPNN (graph neural network)
    - Physics-informed Ridge regression (baseline)
    
    Author: Aitor Olivares Perucho
    Version: 1.0.0
----------------------------------------------------------------------------------------
*/

// ============================================================================
// MANIFEST
// ============================================================================

manifest {
    name            = 'drugsol-predictor'
    author          = 'Aitor Olivares Perucho'
    description     = 'ML pipeline for aqueous solubility prediction'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=22.10.1'
    version         = '1.0.0'
}

// ============================================================================
// GLOBAL PARAMETERS
// ============================================================================

params {
    // -------------------------------------------------------------------------
    // Output and Execution
    // -------------------------------------------------------------------------
    outdir      = "${baseDir}/results"
    mode        = 'research'  // 'research' or 'execution'
    help        = false
    input       = null        // Input file for execution mode
    
    // -------------------------------------------------------------------------
    // Research Specific
    // -------------------------------------------------------------------------
    stratify = 'solvent,T_bin'
    
    // -------------------------------------------------------------------------
    // Execution (Inference) Specific
    // -------------------------------------------------------------------------
    model             = null  // Override model path
    solvent           = null  // Filter by solvent
    temperature_K_Min = null  // Min temperature filter
    temperature_K_Max = null  // Max temperature filter
    
    // -------------------------------------------------------------------------
    // Model Training Toggles
    // -------------------------------------------------------------------------
    skip_xgboost    = false
    skip_lightgbm   = false
    skip_catboost   = false
    skip_chemprop   = false
    skip_physics    = false  // Renamed from skip_regression
    
    // -------------------------------------------------------------------------
    // Cross-Validation Settings
    // -------------------------------------------------------------------------
    n_iterations = 10
    n_cv_folds   = 5
    random_seed  = 42
    
    // -------------------------------------------------------------------------
    // Data Sources
    // -------------------------------------------------------------------------
    bigsoldb_zenodo_id = '15094979'
    reaxys_data        = "${baseDir}/resources/reaxys.csv"
    challenge_data     = "${baseDir}/resources/Second_Challenge_Predict_Aqueous_Solubility.csv"
    
    skip_chembl    = false
    skip_reaxys    = false
    skip_challenge = false
    
    // -------------------------------------------------------------------------
    // Data Curation
    // -------------------------------------------------------------------------
    temp_min_celsius = 24
    temp_max_celsius = 50
    dedup_threshold  = 0.7
    
    // -------------------------------------------------------------------------
    // Reference Files (Execution Mode)
    // -------------------------------------------------------------------------
    ref_train_mordred = "${baseDir}/resources/train_features_mordred_filtered.parquet"
    ref_train_rdkit   = "${baseDir}/resources/train_rdkit_featured.parquet"
    
    // -------------------------------------------------------------------------
    // Feature Engineering
    // -------------------------------------------------------------------------
    feature_set    = 'all'  // 'all', 'mordred_only', 'rdkit_only', 'minimal'
    smarts_patterns = "${baseDir}/resources/smarts_pattern_ionized.txt"
    
    // pKa API
    pka_api_url   = 'http://xundrug.cn:5001/modules/upload0/'
    pka_api_token = 'O05DriqqQLlry9kmpCwms2IJLC0MuLQ7'
    
    // -------------------------------------------------------------------------
    // Fingerprints
    // -------------------------------------------------------------------------
    fingerprint_n_bits         = 2048
    fingerprint_radius         = 2
    fingerprint_cluster_cutoff = 0.7
    
    // -------------------------------------------------------------------------
    // Folds Generation
    // -------------------------------------------------------------------------
    folds_target_col = 'logS'
    folds_n_bins     = 5
    
    // -------------------------------------------------------------------------
    // ChemBERTa Embeddings
    // -------------------------------------------------------------------------
    chemberta_enabled    = true
    chemberta_model      = 'seyonec/ChemBERTa-zinc-base-v1'
    chemberta_batch_size = 32
    chemberta_pooling    = 'cls'
    chemberta_use_gpu    = 'auto'
    
    // -------------------------------------------------------------------------
    // Dataset Merging
    // -------------------------------------------------------------------------
    merge_strategy       = 'inner'
    merge_suffix_primary = ''
    merge_validate       = false
    
    // -------------------------------------------------------------------------
    // Dataset Balancing
    // -------------------------------------------------------------------------
    balance_limit_ambient = 25
    balance_bin_size      = 0.2
    
    // -------------------------------------------------------------------------
    // Stratified Splitting
    // -------------------------------------------------------------------------
    split_temp_step = 5
    split_test_size = 0.2
    
    // -------------------------------------------------------------------------
    // Mordred Descriptors
    // -------------------------------------------------------------------------
    mordred_hash_bins    = 128
    mordred_include_3d   = true
    mordred_force_field  = 'uff'
    mordred_max_atoms_3d = 200
    
    // -------------------------------------------------------------------------
    // Feature Filtering
    // -------------------------------------------------------------------------
    filter_target_col      = 'logS'
    filter_mordred_prefix  = 'mordred__'
    filter_corr_threshold  = 0.99
    filter_importance_algo = 'lgbm'
    
    // -------------------------------------------------------------------------
    // Column Alignment
    // -------------------------------------------------------------------------
    align_onehot_prefix = 'solv_'
    
    // -------------------------------------------------------------------------
    // NaN Row Dropping
    // -------------------------------------------------------------------------
    dropnan_save_csv    = true
    dropnan_subset_mode = 'features_only'
    
    // -------------------------------------------------------------------------
    // GBM OOF Training (XGBoost, LightGBM, CatBoost)
    // -------------------------------------------------------------------------
    gbm_target_col              = 'logS'
    gbm_id_col                  = 'row_uid'
    gbm_weight_col              = 'weight'
    gbm_use_gpu                 = true
    gbm_tune_trials             = 50
    gbm_inner_splits            = 3
    gbm_pruner                  = 'asha'
    gbm_asha_min_resource       = 1
    gbm_asha_reduction_factor   = 3
    gbm_asha_early_stopping_rate = 0
    
    // -------------------------------------------------------------------------
    // Chemprop OOF Training
    // -------------------------------------------------------------------------
    chemprop_smiles_col  = 'smiles_neutral'
    chemprop_id_col      = 'row_uid'
    chemprop_target_col  = 'logS'
    chemprop_weight_col  = 'weight'
    chemprop_epochs      = 50
    chemprop_batch_size  = 32
    chemprop_tune_trials = 20
    chemprop_pruner      = 'asha'
    chemprop_asha_rungs  = 5
    
    // -------------------------------------------------------------------------
    // Physics OOF Training (Ridge baseline)
    // -------------------------------------------------------------------------
    physics_id_col     = 'row_uid'
    physics_target_col = 'logS'
    
    // -------------------------------------------------------------------------
    // Meta Stack Blend
    // -------------------------------------------------------------------------
    meta_metric = 'rmse'
    meta_labels = 'xgb lgbm cat gnn physics'
    
    // -------------------------------------------------------------------------
    // Full GBM Training
    // -------------------------------------------------------------------------
    full_gbm_target_col = 'logS'
    full_gbm_weight_col = 'weight'
    full_gbm_use_gpu    = true
    
    // -------------------------------------------------------------------------
    // Full Chemprop Training
    // -------------------------------------------------------------------------
    full_chemprop_smiles_col  = 'smiles_neutral'
    full_chemprop_target_col  = 'logS'
    full_chemprop_weight_col  = 'weight'
    full_chemprop_epochs      = 50
    full_chemprop_batch_size  = 50
    
    // -------------------------------------------------------------------------
    // Full Physics Training
    // -------------------------------------------------------------------------
    full_physics_target_col = 'logS'
    
    // -------------------------------------------------------------------------
    // Inference
    // -------------------------------------------------------------------------
    infer_id_col     = 'row_uid'
    infer_smiles_col = 'smiles_neutral'
    infer_target_col = 'logS'
    
    // -------------------------------------------------------------------------
    // Final Report
    // -------------------------------------------------------------------------
    report_target_col = 'logS'
    report_id_col     = 'row_uid'
    report_temp_col   = 'temp_C'
    
    // -------------------------------------------------------------------------
    // Prediction
    // -------------------------------------------------------------------------
    prediction_ph = 7.4
}

// ============================================================================
// WORKING DIRECTORY
// ============================================================================

workDir = "${baseDir}/work"

// ============================================================================
// CONDA CONFIGURATION
// ============================================================================

conda {
    enabled       = true
    useMicromamba = true
    cacheDir      = "${baseDir}/envs/conda_cache"
}

// ============================================================================
// PROCESS DEFAULTS
// ============================================================================

process {
    errorStrategy = 'finish'
}

// ============================================================================
// EXECUTION REPORTS
// ============================================================================

// Reports go to results/<mode>/pipeline_info/
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/execution_timeline.html"
}

report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/execution_report.html"
}

trace {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/execution_trace.txt"
}

dag {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/pipeline_dag.html"
}

// ============================================================================
// CLEANUP
// ============================================================================

cleanup = false

// ============================================================================
// VALIDATION (Silence unused params warnings)
// ============================================================================

validation {
    ignoreParams = true  // Don't warn about unused parameters
}

// ============================================================================
// PROFILES
// ============================================================================

profiles {

    // -------------------------------------------------------------------------
    // Standard: CPU-only configuration
    // -------------------------------------------------------------------------
    standard {
        process {
            withLabel: 'cpu_small' {
                cpus   = 1
                memory = '2 GB'
            }
            withLabel: 'cpu_medium' {
                cpus   = 4
                memory = '4 GB'
            }
            withLabel: 'cpu_high' {
                cpus   = 8
                memory = '6 GB'
            }
            withLabel: 'process_gpu' {
                cpus   = 4
                memory = '5 GB'
            }
        }
    }

    // -------------------------------------------------------------------------
    // GPU High: High-performance workstations (A5000, A6000)
    // -------------------------------------------------------------------------
    gpu_high {
        process {
            withLabel: 'cpu_small' {
                cpus   = 1
                memory = '16 GB'
            }
            withLabel: 'cpu_medium' {
                cpus   = 16
                memory = '64 GB'
            }
            withLabel: 'cpu_high' {
                cpus   = 26
                memory = '100 GB'
            }
            withLabel: 'process_gpu' {
                accelerator = 1
                cpus        = 4
                memory      = '32 GB'
                maxForks    = 4
            }
        }
    }

    // -------------------------------------------------------------------------
    // GPU Small: Consumer GPUs with limited VRAM (RTX 3070, 8GB)
    // -------------------------------------------------------------------------
    gpu_small {
        process {
            withLabel: 'cpu_small' {
                cpus   = 1
                memory = '2 GB'
            }
            withLabel: 'cpu_medium' {
                cpus   = 8
                memory = '4 GB'
            }
            withLabel: 'cpu_high' {
                cpus   = 12
                memory = '6 GB'
            }
            withLabel: 'process_gpu' {
                accelerator = 1
                cpus        = 4
                memory      = '6 GB'
                maxForks    = 1
            }
        }
    }

    // -------------------------------------------------------------------------
    // Docker: Containerized execution
    // -------------------------------------------------------------------------
    docker {
        conda.enabled  = false
        docker.enabled = true
    }
}
